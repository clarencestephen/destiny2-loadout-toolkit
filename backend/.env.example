# Copy to backend/.env and fill in. backend/main.py loads /home/cs/.env first,
# then this file as an override.

# CORS — comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost:5173,https://destiny-voyager.clarencestephen.com

# Where the link-completion redirect points (web frontend base URL)
PUBLIC_BASE_URL=https://destiny-voyager.clarencestephen.com

# Env label (just for /health probe display)
BACKEND_ENV=dev
